[{"id":"sb001","question":"りんごが3個あります。4個もらうと全部で何個？","answer":"7","meaning":"はじめにあった3個に、もらった4個をたせばよいので、3＋4＝7個です。","grade":1,"difficulty":1},{"id":"sb002","question":"みかんが8個あります。3個食べると何個残る？","answer":"5","meaning":"はじめにあった8個から食べた3個を引けば残りがわかるので、8－3＝5個です。","grade":1,"difficulty":1},{"id":"sb003","question":"えんぴつが2本、ボールペンが5本。合わせて何本？","answer":"7","meaning":"えんぴつの2とボールペンの5という2つの数量を合わせて求めるので、2＋5＝7本です。","grade":1,"difficulty":1},{"id":"sb004","question":"花が6本あります。2本あげると何本残る？","answer":"4","meaning":"はじめにあった6本からあげた2本を引けば残りがわかるので、6－2＝4本です。","grade":1,"difficulty":1},{"id":"sb005","question":"子どもが4人います。3人来ると何人になる？","answer":"7","meaning":"もといた4人に、来た3人をたせばよいので、4＋3＝7人です。","grade":1,"difficulty":1},{"id":"sb006","question":"りんごが6個あります。3個もらうと全部で何個？","answer":"9","meaning":"はじめにあった6個に、もらった3個をたせばよいので、6＋3＝9個です。","grade":1,"difficulty":1},{"id":"sb007","question":"みかんが10個あります。4個食べると何個残る？","answer":"6","meaning":"はじめにあった10個から食べた4個を引けば残りがわかるので、10－4＝6個です。","grade":1,"difficulty":1},{"id":"sb008","question":"えんぴつが3本、ボールペンが6本。合わせて何本？","answer":"9","meaning":"えんぴつの3とボールペンの6という2つの数量を合わせて求めるので、3＋6＝9本です。","grade":1,"difficulty":1},{"id":"sb009","question":"花が8本あります。3本あげると何本残る？","answer":"5","meaning":"はじめにあった8本からあげた3本を引けば残りがわかるので、8－3＝5本です。","grade":1,"difficulty":1},{"id":"sb010","question":"子どもが6人います。3人来ると何人になる？","answer":"9","meaning":"もといた6人に、来た3人をたせばよいので、6＋3＝9人です。","grade":1,"difficulty":1},{"id":"sb011","question":"クッキーが9枚あります。何枚か食べて5枚になりました。何枚食べた？","answer":"4","meaning":"はじめにあった9枚から、食べたあとに残った5枚を引けば食べた枚数がわかるので、9－5＝4枚です。","grade":1,"difficulty":2},{"id":"sb012","question":"赤い花が5本、白い花が□本。合わせて9本。白は何本？","answer":"4","meaning":"合わせて9本のうち赤が5本なので、白の本数は全体から赤を引いて9－5＝4本です。","grade":1,"difficulty":2},{"id":"sb013","question":"バスに7人乗っていました。3人降りて2人乗りました。今何人？","answer":"6","meaning":"乗っていた7人から降りた3人を引き、そこに新たに乗った2人をたせば今の人数になるので、7－3＋2＝6人です。","grade":1,"difficulty":2},{"id":"sb014","question":"ノートが4冊あります。何冊かもらって8冊になりました。何冊もらった？","answer":"4","meaning":"もらったあとの8冊から、もとの4冊を引けばもらった冊数がわかるので、8－4＝4冊です。","grade":1,"difficulty":2},{"id":"sb015","question":"飴が10個。弟に3個、妹に2個あげると残りは？","answer":"5","meaning":"はじめの10個から弟にあげた3個、さらに妹にあげた2個を順に引いていくので、10－3－2＝5個です。","grade":1,"difficulty":2},{"id":"sb016","question":"クッキーが8枚あります。何枚か食べて3枚になりました。何枚食べた？","answer":"5","meaning":"はじめにあった8枚から、食べたあとに残った3枚を引けば食べた枚数がわかるので、8－3＝5枚です。","grade":1,"difficulty":2},{"id":"sb017","question":"赤い花が6本、白い花が□本。合わせて11本。白は何本？","answer":"5","meaning":"合わせて11本のうち赤が6本なので、白の本数は全体から赤を引いて11－6＝5本です。","grade":1,"difficulty":2},{"id":"sb018","question":"バスに9人乗っていました。4人降りて3人乗りました。今何人？","answer":"8","meaning":"乗っていた9人から降りた4人を引き、そこに新たに乗った3人をたせば今の人数になるので、9－4＋3＝8人です。","grade":1,"difficulty":2},{"id":"sb019","question":"ノートが2冊あります。何冊かもらって8冊になりました。何冊もらった？","answer":"6","meaning":"もらったあとの8冊から、もとの2冊を引けばもらった冊数がわかるので、8－2＝6冊です。","grade":1,"difficulty":2},{"id":"sb020","question":"飴が15個。弟に5個、妹に4個あげると残りは？","answer":"6","meaning":"はじめの15個から弟にあげた5個、さらに妹にあげた4個を順に引いていくので、15－5－4＝6個です。","grade":1,"difficulty":2},{"id":"sb021","question":"□個のお菓子から5個配ると3個残ります。最初は何個？","answer":"8","meaning":"配った5個と、配ったあとに残った3個を合わせれば最初にあった数になるので、5＋3＝8個です。","grade":1,"difficulty":3},{"id":"sb022","question":"□個のお菓子から7個配ると1個残ります。最初は何個？","answer":"8","meaning":"配った7個と、配ったあとに残った1個を合わせれば最初にあった数になるので、7＋1＝8個です。","grade":1,"difficulty":3},{"id":"sb023","question":"□個のお菓子から4個配ると1個残ります。最初は何個？","answer":"5","meaning":"配った4個と、配ったあとに残った1個を合わせれば最初にあった数になるので、4＋1＝5個です。","grade":1,"difficulty":3},{"id":"sb024","question":"□個のお菓子から6個配ると1個残ります。最初は何個？","answer":"7","meaning":"配った6個と、配ったあとに残った1個を合わせれば最初にあった数になるので、6＋1＝7個です。","grade":1,"difficulty":3},{"id":"sb025","question":"□個のお菓子から4個配ると2個残ります。最初は何個？","answer":"6","meaning":"配った4個と、配ったあとに残った2個を合わせれば最初にあった数になるので、4＋2＝6個です。","grade":1,"difficulty":3},{"id":"sb026","question":"□個のお菓子から5個配ると2個残ります。最初は何個？","answer":"7","meaning":"配った5個と、配ったあとに残った2個を合わせれば最初にあった数になるので、5＋2＝7個です。","grade":1,"difficulty":3},{"id":"sb027","question":"□個のお菓子から3個配ると4個残ります。最初は何個？","answer":"7","meaning":"配った3個と、配ったあとに残った4個を合わせれば最初にあった数になるので、3＋4＝7個です。","grade":1,"difficulty":3},{"id":"sb028","question":"□個のお菓子から2個配ると1個残ります。最初は何個？","answer":"3","meaning":"配った2個と、配ったあとに残った1個を合わせれば最初にあった数になるので、2＋1＝3個です。","grade":1,"difficulty":3},{"id":"sb029","question":"□個のお菓子から2個配ると6個残ります。最初は何個？","answer":"8","meaning":"配った2個と、配ったあとに残った6個を合わせれば最初にあった数になるので、2＋6＝8個です。","grade":1,"difficulty":3},{"id":"sb030","question":"□個のお菓子から6個配ると4個残ります。最初は何個？","answer":"10","meaning":"配った6個と、配ったあとに残った4個を合わせれば最初にあった数になるので、6＋4＝10個です。","grade":1,"difficulty":3},{"id":"sb031","question":"1袋に8個入ったお菓子が3袋あります。全部で何個？","answer":"24","meaning":"1袋に8個ずつ入っているお菓子が3袋分あるので、同じ数のまとまりが3つ分と考えて8×3＝24個です。","grade":1,"difficulty":4},{"id":"sb032","question":"1袋に6個入ったお菓子が3袋あります。全部で何個？","answer":"18","meaning":"1袋に6個ずつ入っているお菓子が3袋分あるので、同じ数のまとまりが3つ分と考えて6×3＝18個です。","grade":1,"difficulty":4},{"id":"sb033","question":"1袋に4個入ったお菓子が3袋あります。全部で何個？","answer":"12","meaning":"1袋に4個ずつ入っているお菓子が3袋分あるので、同じ数のまとまりが3つ分と考えて4×3＝12個です。","grade":1,"difficulty":4},{"id":"sb034","question":"1袋に7個入ったお菓子が3袋あります。全部で何個？","answer":"21","meaning":"1袋に7個ずつ入っているお菓子が3袋分あるので、同じ数のまとまりが3つ分と考えて7×3＝21個です。","grade":1,"difficulty":4},{"id":"sb035","question":"1袋に5個入ったお菓子が3袋あります。全部で何個？","answer":"15","meaning":"1袋に5個ずつ入っているお菓子が3袋分あるので、同じ数のまとまりが3つ分と考えて5×3＝15個です。","grade":1,"difficulty":4},{"id":"sb036","question":"1袋に9個入ったお菓子が3袋あります。全部で何個？","answer":"27","meaning":"1袋に9個ずつ入っているお菓子が3袋分あるので、同じ数のまとまりが3つ分と考えて9×3＝27個です。","grade":1,"difficulty":4},{"id":"sb037","question":"1袋に10個入ったお菓子が2袋あります。全部で何個？","answer":"20","meaning":"1袋に10個ずつ入っているお菓子が2袋分あるので、同じ数のまとまりが2つ分と考えて10×2＝20個です。","grade":1,"difficulty":4},{"id":"sb038","question":"1袋に2個入ったお菓子が6袋あります。全部で何個？","answer":"12","meaning":"1袋に2個ずつ入っているお菓子が6袋分あるので、同じ数のまとまりが6つ分と考えて2×6＝12個です。","grade":1,"difficulty":4},{"id":"sb039","question":"1袋に3個入ったお菓子が5袋あります。全部で何個？","answer":"15","meaning":"1袋に3個ずつ入っているお菓子が5袋分あるので、同じ数のまとまりが5つ分と考えて3×5＝15個です。","grade":1,"difficulty":4},{"id":"sb040","question":"1袋に7個入ったお菓子が4袋あります。全部で何個？","answer":"28","meaning":"1袋に7個ずつ入っているお菓子が4袋分あるので、同じ数のまとまりが4つ分と考えて7×4＝28個です。","grade":1,"difficulty":4},{"id":"sb041","question":"シールが10枚あります。5枚使うと残りは？","answer":"5","meaning":"はじめにあった10枚から使った5枚を引けば残りがわかるので、10－5＝5枚です。","grade":2,"difficulty":1},{"id":"sb042","question":"1箱に2個入ったチョコレートが6箱。全部で何個？","answer":"12","meaning":"1箱に2個ずつ入っているチョコレートが6箱分あるので、同じ数のまとまりが6つ分と考えて2×6＝12個です。","grade":2,"difficulty":1},{"id":"sb043","question":"6人に5個ずつ配るには全部で何個必要？","answer":"30","meaning":"1人に5個ずつ6人分用意するので、5×6＝30個必要です。","grade":2,"difficulty":1},{"id":"sb044","question":"本が31冊。14冊読むと残りは？","answer":"17","meaning":"はじめにあった31冊から読んだ14冊を引けば残りがわかるので、31－14＝17冊です。","grade":2,"difficulty":1},{"id":"sb045","question":"シールが24枚あります。11枚使うと残りは？","answer":"13","meaning":"はじめにあった24枚から使った11枚を引けば残りがわかるので、24－11＝13枚です。","grade":2,"difficulty":1},{"id":"sb046","question":"1箱に3個入ったチョコレートが4箱。全部で何個？","answer":"12","meaning":"1箱に3個ずつ入っているチョコレートが4箱分あるので、同じ数のまとまりが4つ分と考えて3×4＝12個です。","grade":2,"difficulty":2},{"id":"sb047","question":"3人に2個ずつ配るには全部で何個必要？","answer":"6","meaning":"1人に2個ずつ3人分用意するので、2×3＝6個必要です。","grade":2,"difficulty":2},{"id":"sb048","question":"本が37冊。31冊読むと残りは？","answer":"6","meaning":"はじめにあった37冊から読んだ31冊を引けば残りがわかるので、37－31＝6冊です。","grade":2,"difficulty":2},{"id":"sb049","question":"シールが21枚あります。7枚使うと残りは？","answer":"14","meaning":"はじめにあった21枚から使った7枚を引けば残りがわかるので、21－7＝14枚です。","grade":2,"difficulty":2},{"id":"sb050","question":"1箱に9個入ったチョコレートが2箱。全部で何個？","answer":"18","meaning":"1箱に9個ずつ入っているチョコレートが2箱分あるので、同じ数のまとまりが2つ分と考えて9×2＝18個です。","grade":2,"difficulty":2},{"id":"sb051","question":"4人に2個ずつ配るには全部で何個必要？","answer":"8","meaning":"1人に2個ずつ4人分用意するので、2×4＝8個必要です。","grade":2,"difficulty":3},{"id":"sb052","question":"本が35冊。11冊読むと残りは？","answer":"24","meaning":"はじめにあった35冊から読んだ11冊を引けば残りがわかるので、35－11＝24冊です。","grade":2,"difficulty":3},{"id":"sb053","question":"シールが20枚あります。16枚使うと残りは？","answer":"4","meaning":"はじめにあった20枚から使った16枚を引けば残りがわかるので、20－16＝4枚です。","grade":2,"difficulty":3},{"id":"sb054","question":"1箱に8個入ったチョコレートが4箱。全部で何個？","answer":"32","meaning":"1箱に8個ずつ入っているチョコレートが4箱分あるので、同じ数のまとまりが4つ分と考えて8×4＝32個です。","grade":2,"difficulty":3},{"id":"sb055","question":"5人に3個ずつ配るには全部で何個必要？","answer":"15","meaning":"1人に3個ずつ5人分用意するので、3×5＝15個必要です。","grade":2,"difficulty":3},{"id":"sb056","question":"本が48冊。24冊読むと残りは？","answer":"24","meaning":"はじめにあった48冊から読んだ24冊を引けば残りがわかるので、48－24＝24冊です。","grade":2,"difficulty":4},{"id":"sb057","question":"シールが11枚あります。7枚使うと残りは？","answer":"4","meaning":"はじめにあった11枚から使った7枚を引けば残りがわかるので、11－7＝4枚です。","grade":2,"difficulty":4},{"id":"sb058","question":"1箱に2個入ったチョコレートが6箱。全部で何個？","answer":"12","meaning":"1箱に2個ずつ入っているチョコレートが6箱分あるので、同じ数のまとまりが6つ分と考えて2×6＝12個です。","grade":2,"difficulty":4},{"id":"sb059","question":"3人に3個ずつ配るには全部で何個必要？","answer":"9","meaning":"1人に3個ずつ3人分用意するので、3×3＝9個必要です。","grade":2,"difficulty":4},{"id":"sb060","question":"本が34冊。16冊読むと残りは？","answer":"18","meaning":"はじめにあった34冊から読んだ16冊を引けば残りがわかるので、34－16＝18冊です。","grade":2,"difficulty":4},{"id":"sb061","question":"6個のクッキーを3人で同じ数ずつ分けると1人何個？","answer":"2","meaning":"クッキー6個を3人で同じ数ずつ分けるので、わり算を使って6÷3＝2個です。","grade":3,"difficulty":1},{"id":"sb062","question":"32個のクッキーを4人で同じ数ずつ分けると1人何個？","answer":"8","meaning":"クッキー32個を4人で同じ数ずつ分けるので、わり算を使って32÷4＝8個です。","grade":3,"difficulty":1},{"id":"sb063","question":"10個のクッキーを2人で同じ数ずつ分けると1人何個？","answer":"5","meaning":"クッキー10個を2人で同じ数ずつ分けるので、わり算を使って10÷2＝5個です。","grade":3,"difficulty":1},{"id":"sb064","question":"16個のクッキーを4人で同じ数ずつ分けると1人何個？","answer":"4","meaning":"クッキー16個を4人で同じ数ずつ分けるので、わり算を使って16÷4＝4個です。","grade":3,"difficulty":1},{"id":"sb065","question":"18個のクッキーを6人で同じ数ずつ分けると1人何個？","answer":"3","meaning":"クッキー18個を6人で同じ数ずつ分けるので、わり算を使って18÷6＝3個です。","grade":3,"difficulty":1},{"id":"sb066","question":"30個のクッキーを5人で同じ数ずつ分けると1人何個？","answer":"6","meaning":"クッキー30個を5人で同じ数ずつ分けるので、わり算を使って30÷5＝6個です。","grade":3,"difficulty":2},{"id":"sb067","question":"18個のクッキーを6人で同じ数ずつ分けると1人何個？","answer":"3","meaning":"クッキー18個を6人で同じ数ずつ分けるので、わり算を使って18÷6＝3個です。","grade":3,"difficulty":2},{"id":"sb068","question":"6個のクッキーを2人で同じ数ずつ分けると1人何個？","answer":"3","meaning":"クッキー6個を2人で同じ数ずつ分けるので、わり算を使って6÷2＝3個です。","grade":3,"difficulty":2},{"id":"sb069","question":"36個のクッキーを6人で同じ数ずつ分けると1人何個？","answer":"6","meaning":"クッキー36個を6人で同じ数ずつ分けるので、わり算を使って36÷6＝6個です。","grade":3,"difficulty":2},{"id":"sb070","question":"10個のクッキーを5人で同じ数ずつ分けると1人何個？","answer":"2","meaning":"クッキー10個を5人で同じ数ずつ分けるので、わり算を使って10÷5＝2個です。","grade":3,"difficulty":2},{"id":"sb071","question":"49枚のカードを6枚ずつ束にすると何束できて何枚余る？","answer":"8余り1","meaning":"カード49枚を6枚ずつの束に分けていくと考えるので、49÷6＝8余り1です。","grade":3,"difficulty":3},{"id":"sb072","question":"7枚のカードを3枚ずつ束にすると何束できて何枚余る？","answer":"2余り1","meaning":"カード7枚を3枚ずつの束に分けていくと考えるので、7÷3＝2余り1です。","grade":3,"difficulty":3},{"id":"sb073","question":"19枚のカードを4枚ずつ束にすると何束できて何枚余る？","answer":"4余り3","meaning":"カード19枚を4枚ずつの束に分けていくと考えるので、19÷4＝4余り3です。","grade":3,"difficulty":3},{"id":"sb074","question":"59枚のカードを9枚ずつ束にすると何束できて何枚余る？","answer":"6余り5","meaning":"カード59枚を9枚ずつの束に分けていくと考えるので、59÷9＝6余り5です。","grade":3,"difficulty":3},{"id":"sb075","question":"42枚のカードを5枚ずつ束にすると何束できて何枚余る？","answer":"8余り2","meaning":"カード42枚を5枚ずつの束に分けていくと考えるので、42÷5＝8余り2です。","grade":3,"difficulty":3},{"id":"sb076","question":"1分間に5m進む虫が40分で何m進む？","answer":"200","meaning":"1分間に5m進むので、40分では同じ速さが40回分になり、5×40＝200mです。","grade":3,"difficulty":4},{"id":"sb077","question":"1分間に5m進む虫が70分で何m進む？","answer":"350","meaning":"1分間に5m進むので、70分では同じ速さが70回分になり、5×70＝350mです。","grade":3,"difficulty":4},{"id":"sb078","question":"1分間に3m進む虫が18分で何m進む？","answer":"54","meaning":"1分間に3m進むので、18分では同じ速さが18回分になり、3×18＝54mです。","grade":3,"difficulty":4},{"id":"sb079","question":"1分間に8m進む虫が48分で何m進む？","answer":"384","meaning":"1分間に8m進むので、48分では同じ速さが48回分になり、8×48＝384mです。","grade":3,"difficulty":4},{"id":"sb080","question":"1分間に2m進む虫が8分で何m進む？","answer":"16","meaning":"1分間に2m進むので、8分では同じ速さが8回分になり、2×8＝16mです。","grade":3,"difficulty":4},{"id":"sb321","question":"ねこが2ひき、いぬが3びきいます。あわせて何びき？","answer":"5","meaning":"ねこの2といぬの3という2つの数量を合わせて求めるので、2＋3＝5びきです。","grade":1,"difficulty":1},{"id":"sb322","question":"おかしが4こあります。2こたべると残りは？","answer":"2","meaning":"はじめにあった4こから食べた2こを引けば残りがわかるので、4－2＝2こです。","grade":1,"difficulty":1},{"id":"sb323","question":"バスに5人のっています。3人おりると何人？","answer":"2","meaning":"乗っていた5人から降りた3人を引けば残りの人数がわかるので、5－3＝2人です。","grade":1,"difficulty":1},{"id":"sb324","question":"えんぴつが3本、ペンが4本。全部で何本？","answer":"7","meaning":"えんぴつの3本とペンの4本を合わせて求めるので、3＋4＝7本です。","grade":1,"difficulty":1},{"id":"sb325","question":"池に金魚が6ひき、メダカが3びき。合わせて何びき？","answer":"9","meaning":"池に金魚の6とメダカの3という2つの数量を合わせて求めるので、6＋3＝9びきです。","grade":1,"difficulty":1},{"id":"sb326","question":"クッキーが8まいあります。4まい食べると残りは？","answer":"4","meaning":"はじめにあった8まいから食べた4まいを引けば残りがわかるので、8－4＝4まいです。","grade":1,"difficulty":1},{"id":"sb327","question":"子どもが7人います。2人帰ると何人残る？","answer":"5","meaning":"いた7人から帰った2人を引けば残りの人数がわかるので、7－2＝5人です。","grade":1,"difficulty":1},{"id":"sb328","question":"赤い花が2本、黄色い花が6本。合わせて何本？","answer":"8","meaning":"赤い花の2と黄色い花の6という2つの数量を合わせて求めるので、2＋6＝8本です。","grade":1,"difficulty":1},{"id":"sb329","question":"本が5さつあります。3さつ読むと残りは？","answer":"2","meaning":"はじめにあった5さつから読んだ3さつを引けば残りがわかるので、5－3＝2さつです。","grade":1,"difficulty":1},{"id":"sb330","question":"ボールが4個あります。3個もらうと全部で何個？","answer":"7","meaning":"はじめにあった4個に、もらった3個をたせばよいので、4＋3＝7個です。","grade":1,"difficulty":1},{"id":"sb331","question":"みかんが9こあります。□こ食べると5こ残ります。何こ食べた？","answer":"4","meaning":"はじめにあった9こから、残った5こを引けば食べた数がわかるので、9－5＝4こです。","grade":1,"difficulty":2},{"id":"sb332","question":"赤と青のビー玉が合わせて8個。赤が3個なら青は？","answer":"5","meaning":"合わせて8個のうち赤が3個なので、青の数は全体から赤を引いて8－3＝5個です。","grade":1,"difficulty":2},{"id":"sb333","question":"1袋に3個入ったキャンディが2袋。全部で何個？","answer":"6","meaning":"1袋に3個ずつ入っているキャンディが2袋分あるので、同じ数のまとまりが2つ分と考えて3×2＝6個です。","grade":1,"difficulty":2},{"id":"sb334","question":"子ども9人のうち女の子が4人。男の子は？","answer":"5","meaning":"全体の9人のうち女の子が4人なので、男の子の数は全体から女の子を引いて9－4＝5人です。","grade":1,"difficulty":2},{"id":"sb335","question":"電車に8人乗っていて3人降りた。今何人？","answer":"5","meaning":"乗っていた8人から降りた3人を引けば今の人数がわかるので、8－3＝5人です。","grade":1,"difficulty":2},{"id":"sb336","question":"あめが7こ、ガムが5こ。あわせて何こ？","answer":"12","meaning":"あめの7とガムの5という2つの数量を合わせて求めるので、7＋5＝12こです。","grade":1,"difficulty":2},{"id":"sb337","question":"花が10本あります。4本あげると残りは？","answer":"6","meaning":"はじめにあった10本からあげた4本を引けば残りがわかるので、10－4＝6本です。","grade":1,"difficulty":2},{"id":"sb338","question":"2＋□＝9。□にはいる数は？","answer":"7","meaning":"2＋□＝9という式なので、□に入る数はたし算の逆のひき算で求められます。9－2＝7です。","grade":1,"difficulty":2},{"id":"sb339","question":"りんごが6こ、バナナが8本。合わせていくつ？","answer":"14","meaning":"りんごの6ことバナナの8本を合わせて求めるので、6＋8＝14です。","grade":1,"difficulty":2},{"id":"sb340","question":"カードが12まいあります。5まいあげると残りは？","answer":"7","meaning":"はじめにあった12まいからあげた5まいを引けば残りがわかるので、12－5＝7まいです。","grade":1,"difficulty":2},{"id":"sb341","question":"1本10円の鉛筆を3本買うと何円？","answer":"30","meaning":"1本10円の鉛筆を3本買うので、10×3＝30円です。","grade":1,"difficulty":3},{"id":"sb342","question":"3人が1人4個ずつどんぐりを拾った。全部で何個？","answer":"12","meaning":"1人が4個ずつ拾い、それが3人分あるので、4×3＝12個です。","grade":1,"difficulty":3},{"id":"sb343","question":"飴が15個。3人で同じ数ずつ分けると1人何個？","answer":"5","meaning":"飴15個を3人で同じ数ずつ分けるので、15÷3＝5個です。","grade":1,"difficulty":3},{"id":"sb344","question":"2段のだんごが4串あります。だんごは全部で何個？","answer":"8","meaning":"1串に2個ずつのだんごが4串分あるので、2×4＝8個です。","grade":1,"difficulty":3},{"id":"sb345","question":"1日に3ページ読む本が15ページ。何日かかる？","answer":"5","meaning":"1日に3ページ読むので、15ページを読み終えるのにかかる日数は15÷3＝5日です。","grade":1,"difficulty":3},{"id":"sb346","question":"6人を2人ずつのグループに分けると何グループ？","answer":"3","meaning":"6人を2人ずつのグループに分けるので、グループの数は6÷2＝3グループです。","grade":1,"difficulty":3},{"id":"sb347","question":"□×4＝20。□にはいる数は？","answer":"5","meaning":"□×4＝20という式なので、□に入る数はかけ算の逆のわり算で求められます。20÷4＝5です。","grade":1,"difficulty":3},{"id":"sb348","question":"12個のビスケットを4枚ずつ配ると何人に配れる？","answer":"3","meaning":"ビスケット12個を4枚ずつ配っていくので、配れる人数は12÷4＝3人です。","grade":1,"difficulty":3},{"id":"sb349","question":"りんごを1人3こずつ5人に配ると全部で何こ必要？","answer":"15","meaning":"1人3こずつ5人に配るので、3×5＝15こ必要です。","grade":1,"difficulty":3},{"id":"sb350","question":"20このあめを4人で同じ数ずつ分けると1人何こ？","answer":"5","meaning":"あめ20こを4人で同じ数ずつ分けるので、20÷4＝5こです。","grade":1,"difficulty":3},{"id":"sb351","question":"バスに14人乗っています。4人降りて7人乗ると今何人？","answer":"17","meaning":"乗っていた14人から降りた4人を引き、そこに新たに乗った7人をたせば今の人数になるので、14－4＋7＝17人です。","grade":1,"difficulty":4},{"id":"sb352","question":"1袋5個入りのお菓子が3袋。全部で何個で、7個食べると残りは？","answer":"8","meaning":"まず全部の個数を求めると、1袋5個が3袋分で5×3＝15個です。ここから食べた7個を引くと、残りは15－7＝8個です。","grade":1,"difficulty":4},{"id":"sb353","question":"3×□＝18、□＝？その数に2を足すと？","answer":"8","meaning":"3×□＝18より□＝18÷3＝6です。この数に2をたすと、6＋2＝8になります。","grade":1,"difficulty":4},{"id":"sb354","question":"池に魚が20匹。毎日3匹釣ると5日後に残りは？","answer":"5","meaning":"毎日3匹ずつ5日間釣るので、釣った合計は3×5＝15匹です。はじめの20匹からこれを引くと、残りは20－15＝5匹です。","grade":1,"difficulty":4},{"id":"sb355","question":"お菓子を3人に4個ずつ配ったら2個余った。最初は何個？","answer":"14","meaning":"3人に4個ずつ配った分は4×3＝12個です。これに余った2個をたせば最初の個数になるので、12＋2＝14個です。","grade":1,"difficulty":4},{"id":"sb356","question":"1列に5人が4列並んでいる。全員で何人？","answer":"20","meaning":"1列5人が4列分あるので、5×4＝20人です。","grade":1,"difficulty":4},{"id":"sb357","question":"24このビー玉を3人で分けた。1人分より2こ多いのは何こ？","answer":"10","meaning":"まず1人分を求めると24÷3＝8こです。それより2こ多い数を求めるので、8＋2＝10こです。","grade":1,"difficulty":4},{"id":"sb358","question":"□÷4＝5あまり2。□は？","answer":"22","meaning":"わり算とあまりの関係「わる数×商＋あまり＝わられる数」を使います。4×5＝20、これに あまりの2をたして20＋2＝22です。","grade":1,"difficulty":4},{"id":"sb359","question":"1個80円のパンを3個と60円の飲み物1本。合計は？","answer":"300","meaning":"パンの代金は80×3＝240円です。これに飲み物の60円をたして、240＋60＝300円です。","grade":1,"difficulty":4},{"id":"sb360","question":"15人を3つのグループに等しく分けると1グループ何人？","answer":"5","meaning":"15人を3つのグループに等しく分けるので、15÷3＝5人です。","grade":1,"difficulty":4},{"id":"sb361","question":"1袋12個入りのクッキーが3袋。全部で何個？","answer":"36","meaning":"1袋12個入りのクッキーがが3袋あるので、12×3＝36個です。","grade":2,"difficulty":1},{"id":"sb362","question":"50枚のシールを8枚使うと残りは？","answer":"42","meaning":"はじめにあった50枚から使った8枚を引けば残りがわかるので、50－8＝42枚です。","grade":2,"difficulty":1},{"id":"sb363","question":"1箱24本入りの鉛筆が2箱。全部で何本？","answer":"48","meaning":"1箱24本入りの鉛筆が2箱あるので、24×2＝48本です。","grade":2,"difficulty":1},{"id":"sb364","question":"80円のパンと60円のジュース。合計は？","answer":"140","meaning":"パンの80円とジュースの60円をたし合わせるので、80＋60＝140円です。","grade":2,"difficulty":1},{"id":"sb365","question":"3人に7個ずつチョコを配ると全部で何個？","answer":"21","meaning":"1人に7個ずつ3人分用意するので、7×3＝21個必要です。","grade":2,"difficulty":1},{"id":"sb366","question":"教室に35人います。12人帰ると残りは？","answer":"23","meaning":"教室にいた35人から帰った12人を引けば残りがわかるので、35－12＝23人です。","grade":2,"difficulty":1},{"id":"sb367","question":"1mの布を5人で等しく分けると1人何cm？","answer":"20","meaning":"1mは100cmなので、これを5人で等しく分けると、100÷5＝20cmです。","grade":2,"difficulty":1},{"id":"sb368","question":"4×9は？","answer":"36","meaning":"4のまとまりが9つ分あると考えて、4×9＝36と計算します。","grade":2,"difficulty":1},{"id":"sb369","question":"6の段：6×7＝？","answer":"42","meaning":"6の段の九九を使って、6×7＝42と求められます。","grade":2,"difficulty":1},{"id":"sb370","question":"72÷8＝？","answer":"9","meaning":"72を8個ずつのまとまりに分けると考えて計算すると、72÷8＝9です。","grade":2,"difficulty":1},{"id":"sb371","question":"9×8＝？","answer":"72","meaning":"9のまとまりが8つ分あると考えて計算すると、9×8＝72です。","grade":2,"difficulty":1},{"id":"sb372","question":"63÷7＝？","answer":"9","meaning":"63を7個ずつのまとまりに分けると考えて計算すると、63÷7＝9です。","grade":2,"difficulty":1},{"id":"sb373","question":"4×6＋5＝？","answer":"29","meaning":"かけ算・わり算をたし算・ひき算より先に計算します。4×6＝24となるので、24＋5＝29です。","grade":2,"difficulty":1},{"id":"sb374","question":"50－8×4＝？","answer":"18","meaning":"かけ算・わり算をたし算・ひき算より先に計算します。8×4＝32となるので、50－32＝18です。","grade":2,"difficulty":1},{"id":"sb375","question":"3×8＝？","answer":"24","meaning":"3のまとまりが8つ分あると考えて計算すると、3×8＝24です。","grade":2,"difficulty":1},{"id":"sb376","question":"1人3個のみかんを12人に配ると全部で何個？","answer":"36","meaning":"1人3個ずつ12人に配るので、3×12＝36個です。","grade":2,"difficulty":2},{"id":"sb377","question":"48個のあめを6人で等しく分けると1人何個？","answer":"8","meaning":"あめ48個を6人で等しく分けるので、48÷6＝8個です。","grade":2,"difficulty":2},{"id":"sb378","question":"5×□＝45。□は？","answer":"9","meaning":"5×□＝45という式なので、□に入る数はかけ算の逆のわり算で求められます。45÷5＝9です。","grade":2,"difficulty":2},{"id":"sb379","question":"□×7＝56。□は？","answer":"8","meaning":"□×7＝56という式なので、□に入る数はかけ算の逆のわり算で求められます。56÷7＝8です。","grade":2,"difficulty":2},{"id":"sb380","question":"1本25円の鉛筆を4本買うと何円？","answer":"100","meaning":"1本25円の鉛筆を4本買うので、25×4＝100円です。","grade":2,"difficulty":2},{"id":"sb381","question":"120円持っています。80円のジュースを買うとお釣りは？","answer":"40","meaning":"持っている120円からジュースの代金80円を引けばお釣りになるので、120－80＝40円です。","grade":2,"difficulty":2},{"id":"sb382","question":"1袋に8個入ったお菓子を6袋買いました。全部で何個？","answer":"48","meaning":"1袋8個入りのお菓子を6袋買ったので、8×6＝48個です。","grade":2,"difficulty":2},{"id":"sb383","question":"56÷8＝？","answer":"7","meaning":"56を8個ずつのまとまりに分けると考えて計算すると、56÷8＝7です。","grade":2,"difficulty":2},{"id":"sb384","question":"7×□＝63。□は？","answer":"9","meaning":"7×□＝63という式なので、□に入る数はかけ算の逆のわり算で求められます。63÷7＝9です。","grade":2,"difficulty":2},{"id":"sb385","question":"45個のビー玉を5人で分けると1人何個？","answer":"9","meaning":"ビー玉45個を5人で分けるので、45÷5＝9個です。","grade":2,"difficulty":2},{"id":"sb386","question":"4×7＋6＝？","answer":"34","meaning":"かけ算・わり算をたし算・ひき算より先に計算します。4×7＝28となるので、28＋6＝34です。","grade":2,"difficulty":2},{"id":"sb387","question":"100－6×9＝？","answer":"46","meaning":"かけ算・わり算をたし算・ひき算より先に計算します。6×9＝54となるので、100－54＝46です。","grade":2,"difficulty":2},{"id":"sb388","question":"3×□＝27。□は？","answer":"9","meaning":"3×□＝27という式なので、□に入る数はかけ算の逆のわり算で求められます。27÷3＝9です。","grade":2,"difficulty":2},{"id":"sb389","question":"72個のチョコを8個ずつ袋に入れると何袋？","answer":"9","meaning":"チョコ72個を8個ずつ袋に入れていくので、袋の数は72÷8＝9袋です。","grade":2,"difficulty":2},{"id":"sb390","question":"6×8＝？","answer":"48","meaning":"6のまとまりが8つ分あると考えて計算すると、6×8＝48です。","grade":2,"difficulty":2},{"id":"sb391","question":"1個150円のケーキを3個と200円の飲み物。合計は？","answer":"650","meaning":"ケーキの代金は150×3＝450円です。これに飲み物の200円をたして、450＋200＝650円です。","grade":2,"difficulty":3},{"id":"sb392","question":"9×9＋4＝？","answer":"85","meaning":"かけ算・わり算をたし算・ひき算より先に計算します。9×9＝81となるので、81＋4＝85です。","grade":2,"difficulty":3},{"id":"sb393","question":"100円玉3枚と50円玉4枚の合計は？","answer":"500","meaning":"100円玉が3枚で100×3＝300円、50円玉が4枚で50×4＝200円です。これらをたして、300＋200＝500円です。","grade":2,"difficulty":3},{"id":"sb394","question":"5×□＋3＝38。□は？","answer":"7","meaning":"5×□＋3＝38という式なので、まず両辺から3を引いて5×□＝38－3＝35とします。□は35÷5＝7です。","grade":2,"difficulty":3},{"id":"sb395","question":"1列8人が9列。全員で何人？","answer":"72","meaning":"1列8人が9列分あるので、8×9＝72人です。","grade":2,"difficulty":3},{"id":"sb396","question":"84個のお菓子を7人で分けると1人何個？","answer":"12","meaning":"お菓子84個を7人で分けるので、84÷7＝12個です。","grade":2,"difficulty":3},{"id":"sb397","question":"3×8－7＝？","answer":"17","meaning":"かけ算・わり算をたし算・ひき算より先に計算します。3×8＝24となるので、24－7＝17です。","grade":2,"difficulty":3},{"id":"sb398","question":"□÷6＝9。□は？","answer":"54","meaning":"□÷6＝9という式なので、□に入る数はわり算の逆のかけ算で求められます。6×9＝54です。","grade":2,"difficulty":3},{"id":"sb399","question":"1袋9個入りのクッキーを7袋。全部で何個？","answer":"63","meaning":"1袋9個入りのクッキーが7袋あるので、9×7＝63個です。","grade":2,"difficulty":3},{"id":"sb400","question":"50円切手を8枚買うと何円？","answer":"400","meaning":"1枚50円の切手を8枚買うので、50×8＝400円です。","grade":2,"difficulty":3},{"id":"sb401","question":"6×□＝54。□は？","answer":"9","meaning":"6×□＝54という式なので、□に入る数はかけ算の逆のわり算で求められます。54÷6＝9です。","grade":2,"difficulty":3},{"id":"sb402","question":"7×6＋8＝？","answer":"50","meaning":"かけ算・わり算をたし算・ひき算より先に計算します。7×6＝42となるので、42＋8＝50です。","grade":2,"difficulty":3},{"id":"sb403","question":"1人8個ずつ7人に配ると全部で何個必要？","answer":"56","meaning":"1人に8個ずつ7人分用意するので、8×7＝56個必要です。","grade":2,"difficulty":3},{"id":"sb404","question":"90÷9＝？","answer":"10","meaning":"90を9個ずつのまとまりに分けると考えて計算すると、90÷9＝10です。","grade":2,"difficulty":3},{"id":"sb405","question":"4×□＝36。□は？","answer":"9","meaning":"4×□＝36という式なので、□に入る数はかけ算の逆のわり算で求められます。36÷4＝9です。","grade":2,"difficulty":3},{"id":"sb406","question":"300円持って80円のパンと120円のジュースを買うとお釣りは？","answer":"100","meaning":"パンの80円とジュースの120円をたすと代金の合計は80＋120＝200円です。持っている300円からこれを引くと、お釣りは300－200＝100円です。","grade":2,"difficulty":4},{"id":"sb407","question":"□×8＝96。□は？","answer":"12","meaning":"□×8＝96という式なので、□に入る数はかけ算の逆のわり算で求められます。96÷8＝12です。","grade":2,"difficulty":4},{"id":"sb408","question":"1人9個ずつ、8人に配ると全部で何個？8個余っている場合、最初は何個？","answer":"80","meaning":"1人に9個ずつ8人分配ると9×8＝72個です。さらに8個余っていたことをたすと、最初の個数は72＋8＝80個です。","grade":2,"difficulty":4},{"id":"sb409","question":"6×8＋7×5＝？","answer":"83","meaning":"かけ算・わり算をたし算・ひき算より先に計算します。6×8＝48、7×5＝35となるので、48＋35＝83です。","grade":2,"difficulty":4},{"id":"sb410","question":"みかんが96個。8個ずつ箱に入れると何箱？","answer":"12","meaning":"みかん96個を8個ずつ箱に入れていくので、箱の数は96÷8＝12箱です。","grade":2,"difficulty":4},{"id":"sb411","question":"1枚12円の切手を8枚と1枚50円の切手を3枚。合計は？","answer":"246","meaning":"12円の切手8枚で12×8＝96円、50円の切手3枚で50×3＝150円です。これらをたして、96＋150＝246円です。","grade":2,"difficulty":4},{"id":"sb412","question":"4×□－5＝31。□は？","answer":"9","meaning":"4×□－5＝31という式なので、まず両辺に5をたして4×□＝31＋5＝36とします。□は36÷4＝9です。","grade":2,"difficulty":4},{"id":"sb413","question":"1袋7個入り×9袋＋8個。全部で何個？","answer":"71","meaning":"1袋7個入りが9袋で7×9＝63個、これにばら売りの8個をたして、63＋8＝71個です。","grade":2,"difficulty":4},{"id":"sb414","question":"108÷9＝？","answer":"12","meaning":"108を9個ずつのまとまりに分けると考えて計算すると、108÷9＝12です。","grade":2,"difficulty":4},{"id":"sb415","question":"□÷8＝11。□は？","answer":"88","meaning":"□÷8＝11という式なので、□に入る数はわり算の逆のかけ算で求められます。8×11＝88です。","grade":2,"difficulty":4},{"id":"sb416","question":"6×9＋4×8＝？","answer":"86","meaning":"かけ算・わり算をたし算・ひき算より先に計算します。6×9＝54、4×8＝32となるので、54＋32＝86です。","grade":2,"difficulty":4},{"id":"sb417","question":"130円のパンを3個。500円払うとお釣りは？","answer":"110","meaning":"パンの代金は130×3＝390円です。支払った500円からこれを引くと、お釣りは500－390＝110円です。","grade":2,"difficulty":4},{"id":"sb418","question":"9の段をすべて足すと？（9×1＋9×2＋…＋9×9）","answer":"405","meaning":"9の段は9×1から9×9までなので、9が(1＋2＋…＋9)＝45個分あると考えられます。よって9×45＝405です。","grade":2,"difficulty":4},{"id":"sb419","question":"□×7＝84。□は？","answer":"12","meaning":"□×7＝84という式なので、□に入る数はかけ算の逆のわり算で求められます。84÷7＝12です。","grade":2,"difficulty":4},{"id":"sb420","question":"48÷6＋9×7＝？","answer":"71","meaning":"かけ算・わり算をたし算・ひき算より先に計算します。48÷6＝8、9×7＝63となるので、8＋63＝71です。","grade":2,"difficulty":4},{"id":"sb421","question":"1箱48個入りのチョコを6箱。全部で何個？","answer":"288","meaning":"1箱48個入りのチョコが6箱あるので、48×6＝288個です。","grade":3,"difficulty":1},{"id":"sb422","question":"480mのリボンを6等分すると1本何m？","answer":"80","meaning":"リボン480mを6等分するので、480÷6＝80mです。","grade":3,"difficulty":1},{"id":"sb423","question":"1冊150円のノートを4冊。合計は？","answer":"600","meaning":"1冊150円のノートを4冊買うので、150×4＝600円です。","grade":3,"difficulty":1},{"id":"sb424","question":"350個のビーズを7人で分けると1人何個？","answer":"50","meaning":"ビーズ350個を7人で分けるので、350÷7＝50個です。","grade":3,"difficulty":1},{"id":"sb425","question":"1分間に60m歩く人が5分で何m進む？","answer":"300","meaning":"1分間に60m歩くので、5分ではその5倍進むと考えて、60×5＝300mです。","grade":3,"difficulty":1},{"id":"sb426","question":"256＋384＝？","answer":"640","meaning":"2つの数をそのままたし合わせて、256＋384＝640と計算します。","grade":3,"difficulty":1},{"id":"sb427","question":"1本75円の鉛筆を8本買うと何円？","answer":"600","meaning":"1本75円の鉛筆を8本買うので、75×8＝600円です。","grade":3,"difficulty":1},{"id":"sb428","question":"700－256＝？","answer":"444","meaning":"大きい数から小さい数を引いて、700－256＝444と計算します。","grade":3,"difficulty":1},{"id":"sb429","question":"24×5＝？","answer":"120","meaning":"24のまとまりが5つ分あると考えて計算すると、24×5＝120です。","grade":3,"difficulty":1},{"id":"sb430","question":"84÷7＝？","answer":"12","meaning":"84を7個ずつのまとまりに分けると考えて計算すると、84÷7＝12です。","grade":3,"difficulty":1},{"id":"sb431","question":"125×4＝？","answer":"500","meaning":"125のまとまりが4つ分あると考えて計算すると、125×4＝500です。","grade":3,"difficulty":1},{"id":"sb432","question":"96÷8＝？","answer":"12","meaning":"96を8個ずつのまとまりに分けると考えて計算すると、96÷8＝12です。","grade":3,"difficulty":1},{"id":"sb433","question":"13×6＝？","answer":"78","meaning":"13のまとまりが6つ分あると考えて計算すると、13×6＝78です。","grade":3,"difficulty":1},{"id":"sb434","question":"144÷12＝？","answer":"12","meaning":"144を12個ずつのまとまりに分けると考えて計算すると、144÷12＝12です。","grade":3,"difficulty":1},{"id":"sb435","question":"1mのテープを4等分すると1本は何cm？","answer":"25","meaning":"1mは100cmなので、これを4等分すると、100÷4＝25cmです。","grade":3,"difficulty":1},{"id":"sb436","question":"650円持って280円の本を買うとお釣りは？","answer":"370","meaning":"持っている650円から本の代金280円を引けばお釣りになるので、650－280＝370円です。","grade":3,"difficulty":2},{"id":"sb437","question":"23×14＝？","answer":"322","meaning":"23のまとまりが14回分あると考えて計算すると、23×14＝322です。","grade":3,"difficulty":2},{"id":"sb438","question":"168÷8＝？","answer":"21","meaning":"168を8個ずつのまとまりに分けると考えて計算すると、168÷8＝21です。","grade":3,"difficulty":2},{"id":"sb439","question":"1日3kmジョギングする人が2週間で何km？","answer":"42","meaning":"2週間は2×7＝14日です。1日に3km走るので、3×14＝42kmになります。","grade":3,"difficulty":2},{"id":"sb440","question":"480mLのジュースを6人で等しく分けると1人何mL？","answer":"80","meaning":"ジュース480mLを6人で等しく分けるので、480÷6＝80mLです。","grade":3,"difficulty":2},{"id":"sb441","question":"45×12＝？","answer":"540","meaning":"45のまとまりが12回分あると考えて計算すると、45×12＝540です。","grade":3,"difficulty":2},{"id":"sb442","question":"252÷12＝？","answer":"21","meaning":"252を12個ずつのまとまりに分けると考えて計算すると、252÷12＝21です。","grade":3,"difficulty":2},{"id":"sb443","question":"1個85円のりんごを12個買うと何円？","answer":"1020","meaning":"1個85円のりんごを12個買うので、85×12＝1020円です。","grade":3,"difficulty":2},{"id":"sb444","question":"時速6kmで歩く人が3時間で何km進む？","answer":"18","meaning":"時速6kmとは1時間に6km進む速さなので、3時間では6×3＝18km進みます。","grade":3,"difficulty":2},{"id":"sb445","question":"32×25＝？","answer":"800","meaning":"32のまとまりが25回分あると考えて計算すると、32×25＝800です。","grade":3,"difficulty":2},{"id":"sb446","question":"1袋24個入り×15袋。全部で何個？","answer":"360","meaning":"1袋24個入りが15袋あるので、24×15＝360個です。","grade":3,"difficulty":2},{"id":"sb447","question":"480÷15＝？","answer":"32","meaning":"480を15個ずつのまとまりに分けると考えて計算すると、480÷15＝32です。","grade":3,"difficulty":2},{"id":"sb448","question":"1人165円のケーキを8人分。合計は？","answer":"1320","meaning":"1人分165円が8人分あるので、165×8＝1320円です。","grade":3,"difficulty":2},{"id":"sb449","question":"630÷9＝？","answer":"70","meaning":"630を9個ずつのまとまりに分けると考えて計算すると、630÷9＝70です。","grade":3,"difficulty":2},{"id":"sb450","question":"56×14＝？","answer":"784","meaning":"56のまとまりが14回分あると考えて計算すると、56×14＝784です。","grade":3,"difficulty":2},{"id":"sb451","question":"840gの砂糖を7等分すると1袋何g？","answer":"120","meaning":"砂糖840gを7等分するので、840÷7＝120gです。","grade":3,"difficulty":3},{"id":"sb452","question":"1個120円のみかんを15個。2000円払うとお釣りは？","answer":"200","meaning":"みかん15個分の代金は120×15＝1800円です。支払った2000円との差がお釣りになるので、2000－1800＝200円です。","grade":3,"difficulty":3},{"id":"sb453","question":"時速4kmで歩く人と時速12kmで走る人。1時間後の差は？","answer":"8","meaning":"1時間後、歩く人は4×1＝4km、走る人は12×1＝12km進みます。この差を求めると、12－4＝8kmです。","grade":3,"difficulty":3},{"id":"sb454","question":"1箱36個入りのお菓子を4人で等しく分けると1人何個？","answer":"9","meaning":"1箱36個入りのお菓子を4人で等しく分けるので、36÷4＝9個です。","grade":3,"difficulty":3},{"id":"sb455","question":"25×36＝？","answer":"900","meaning":"25のまとまりが36回分あると考えて計算すると、25×36＝900です。","grade":3,"difficulty":3},{"id":"sb456","question":"756÷12＝？","answer":"63","meaning":"756を12個ずつのまとまりに分けると考えて計算すると、756÷12＝63です。","grade":3,"difficulty":3},{"id":"sb457","question":"1L（1000mL）のジュースを6人で分けると1人何mLで何mL余る？","answer":"166余り4","meaning":"1000mLのジュースを6人で等しく分けると考えるので、1000÷6＝166余り4です。","grade":3,"difficulty":3},{"id":"sb458","question":"15×48＝？","answer":"720","meaning":"15のまとまりが48回分あると考えて計算すると、15×48＝720です。","grade":3,"difficulty":3},{"id":"sb459","question":"1枚80円の切手と1枚150円の切手を各5枚ずつ買うと合計は？","answer":"1150","meaning":"80円の切手5枚で80×5＝400円、150円の切手5枚で150×5＝750円です。これらをたして、400＋750＝1150円です。","grade":3,"difficulty":3},{"id":"sb460","question":"480を12で割ると？","answer":"40","meaning":"480を12等分すると考えて、480÷12＝40と求められます。","grade":3,"difficulty":3},{"id":"sb461","question":"1分間に15m進む虫が2時間で何m進む？","answer":"1800","meaning":"2時間は2×60＝120分です。1分間に15m進むので、15×120＝1800mです。","grade":3,"difficulty":3},{"id":"sb462","question":"□×18＝540。□は？","answer":"30","meaning":"□×18＝540という式なので、□に入る数はかけ算の逆のわり算で求められます。540÷18＝30です。","grade":3,"difficulty":3},{"id":"sb463","question":"25×□＝600。□は？","answer":"24","meaning":"25×□＝600という式なので、□に入る数はかけ算の逆のわり算で求められます。600÷25＝24です。","grade":3,"difficulty":3},{"id":"sb464","question":"1袋45個×24袋。全部で何個？","answer":"1080","meaning":"1袋45個入りが24袋あるので、45×24＝1080個です。","grade":3,"difficulty":3},{"id":"sb465","question":"630÷14＝？","answer":"45","meaning":"630を14個ずつのまとまりに分けると考えて計算すると、630÷14＝45です。","grade":3,"difficulty":3},{"id":"sb466","question":"時速60kmの車が2時間30分で何km進む？","answer":"150","meaning":"2時間30分は2＋30÷60＝2.5時間です。時速60kmなので、60×2.5＝150kmです。","grade":3,"difficulty":4},{"id":"sb467","question":"1個150円のりんごと1個80円のみかんを合わせて10個買って1080円。りんごは何個？","answer":"4","meaning":"10個全部をみかん（1個80円）だったと考えると、代金は80×10＝800円になり、実際の1080円との差は1080－800＝280円です。りんご1個をみかんの代わりに買うたびに代金は150－80＝70円ずつ増えるので、りんごの個数は280÷70＝4個です。","grade":3,"difficulty":4},{"id":"sb468","question":"1080÷24＝？","answer":"45","meaning":"1080を24個ずつのまとまりに分けると考えて計算すると、1080÷24＝45です。","grade":3,"difficulty":4},{"id":"sb469","question":"面積が576cm²の正方形の1辺は？","answer":"24","meaning":"正方形の面積は1辺×1辺で求められるので、同じ数を2回かけて576になる数をさがします。24×24＝576なので、1辺＝24です。","grade":3,"difficulty":4},{"id":"sb470","question":"1分間に120m歩く人と分速80mで歩く人が反対方向に歩く。3分後の距離は？","answer":"600","meaning":"反対方向に歩くと2人の間の距離は1分ごとに120＋80＝200mずつ広がります。3分後の距離は200×3＝600mです。","grade":3,"difficulty":4},{"id":"sb471","question":"36×□＝1512。□は？","answer":"42","meaning":"36×□＝1512という式なので、□に入る数はかけ算の逆のわり算で求められます。1512÷36＝42です。","grade":3,"difficulty":4},{"id":"sb472","question":"1箱24個入りのお菓子。□箱で1008個になる。□は？","answer":"42","meaning":"1箱24個入りで合計1008個になる箱の数を求めるので、1008÷24＝42箱です。","grade":3,"difficulty":4},{"id":"sb473","question":"980円のものを3個買って5000円払うとお釣りは？","answer":"2060","meaning":"ものの代金は980×3＝2940円です。支払った5000円からこれを引くと、お釣りは5000－2940＝2060円です。","grade":3,"difficulty":4},{"id":"sb474","question":"1Lのペットボトルを12本買った。2.5L飲んだ。残りは何mL？","answer":"9500","meaning":"1Lのペットボトル12本で全部12×1000＝12000mLです。飲んだ2.5Lは2500mLなので、残りは12000－2500＝9500mLです。","grade":3,"difficulty":4},{"id":"sb475","question":"45×□＝2025。□は？","answer":"45","meaning":"45×□＝2025という式なので、□に入る数はかけ算の逆のわり算で求められます。2025÷45＝45です。","grade":3,"difficulty":4},{"id":"sb476","question":"毎分200mで走る人が3600m走るのに何分かかる？","answer":"18","meaning":"毎分200mで走るので、3600mを走るのにかかる時間は3600÷200＝18分です。","grade":3,"difficulty":4},{"id":"sb477","question":"1個85円のお菓子を24個まとめて2080円で買うとお釣りは？","answer":"40","meaning":"お菓子24個分の代金を求めると、85×24＝2040円です。支払った2080円との差がお釣りになるので、2080－2040＝40円です。","grade":3,"difficulty":4},{"id":"sb478","question":"長さ900cmのテープを15等分すると1本何cm？","answer":"60","meaning":"テープ900cmを15等分するので、900÷15＝60cmです。","grade":3,"difficulty":4},{"id":"sb479","question":"28×□＝1540。□は？","answer":"55","meaning":"28×□＝1540という式なので、□に入る数はかけ算の逆のわり算で求められます。1540÷28＝55です。","grade":3,"difficulty":4},{"id":"sb480","question":"1日240ページ読む本が3600ページ。何日かかる？","answer":"15","meaning":"1日に240ページ読むので、3600ページを読み終えるのにかかる日数は3600÷240＝15日です。","grade":3,"difficulty":4},{"id":"sb961","question":"Aさんがあめを15個、Bさんが30個、Cさんが30個持っています。3人合わせてあめは何個ありますか？","answer":"75","meaning":"Aさん・Bさん・Cさんそれぞれが持っているあめの個数を全部たし合わせれば3人合計のあめの数になるので、15＋30＋30＝75個です。","grade":4,"difficulty":1},{"id":"sb962","question":"あめを12個持っていました。6個あげて、その後5個もらいました。今、あめは何個ありますか？","answer":"11","meaning":"はじめの12個からあげた6個を引き、そのあとにもらった5個をたせば今の個数になるので、12－6＋5＝11個です。","grade":4,"difficulty":1},{"id":"sb963","question":"みかんを26個持っていました。6個あげて、その後8個もらいました。今、みかんは何個ありますか？","answer":"28","meaning":"はじめの26個からあげた6個を引き、そのあとにもらった8個をたせば今の個数になるので、26－6＋8＝28個です。","grade":4,"difficulty":1},{"id":"sb964","question":"Aさんがりんごを20個、Bさんが17個、Cさんが14個持っています。3人合わせてりんごは何個ありますか？","answer":"51","meaning":"Aさん・Bさん・Cさんそれぞれが持っているりんごの個数を全部たし合わせれば3人合計のりんごの数になるので、20＋17＋14＝51個です。","grade":4,"difficulty":1},{"id":"sb965","question":"Aさんがりんごを14個、Bさんが28個、Cさんが18個持っています。3人合わせてりんごは何個ありますか？","answer":"60","meaning":"Aさん・Bさん・Cさんそれぞれが持っているりんごの個数を全部たし合わせれば3人合計のりんごの数になるので、14＋28＋18＝60個です。","grade":4,"difficulty":1},{"id":"sb966","question":"Aさんがノートを19個、Bさんが16個、Cさんが16個持っています。3人合わせてノートは何個ありますか？","answer":"51","meaning":"Aさん・Bさん・Cさんそれぞれが持っているノートの個数を全部たし合わせれば3人合計のノートの数になるので、19＋16＋16＝51個です。","grade":4,"difficulty":1},{"id":"sb967","question":"色えんぴつを13個持っていました。13個あげて、その後4個もらいました。今、色えんぴつは何個ありますか？","answer":"4","meaning":"はじめの13個からあげた13個を引き、そのあとにもらった4個をたせば今の個数になるので、13－13＋4＝4個です。","grade":4,"difficulty":1},{"id":"sb968","question":"みかんを22個持っていました。1個あげて、その後15個もらいました。今、みかんは何個ありますか？","answer":"36","meaning":"はじめの22個からあげた1個を引き、そのあとにもらった15個をたせば今の個数になるので、22－1＋15＝36個です。","grade":4,"difficulty":1},{"id":"sb969","question":"Aさんがクッキーを10個、Bさんが17個、Cさんが19個持っています。3人合わせてクッキーは何個ありますか？","answer":"46","meaning":"Aさん・Bさん・Cさんそれぞれが持っているクッキーの個数を全部たし合わせれば3人合計のクッキーの数になるので、10＋17＋19＝46個です。","grade":4,"difficulty":1},{"id":"sb970","question":"クッキーを28個持っていました。20個あげて、その後10個もらいました。今、クッキーは何個ありますか？","answer":"18","meaning":"はじめの28個からあげた20個を引き、そのあとにもらった10個をたせば今の個数になるので、28－20＋10＝18個です。","grade":4,"difficulty":1},{"id":"sb971","question":"色えんぴつを21個持っていました。19個あげて、その後6個もらいました。今、色えんぴつは何個ありますか？","answer":"8","meaning":"はじめの21個からあげた19個を引き、そのあとにもらった6個をたせば今の個数になるので、21－19＋6＝8個です。","grade":4,"difficulty":1},{"id":"sb972","question":"色えんぴつを24個持っていました。7個あげて、その後11個もらいました。今、色えんぴつは何個ありますか？","answer":"28","meaning":"はじめの24個からあげた7個を引き、そのあとにもらった11個をたせば今の個数になるので、24－7＋11＝28個です。","grade":4,"difficulty":1},{"id":"sb973","question":"Aさんが色えんぴつを11個、Bさんが29個、Cさんが7個持っています。3人合わせて色えんぴつは何個ありますか？","answer":"47","meaning":"Aさん・Bさん・Cさんそれぞれが持っている色えんぴつの個数を全部たし合わせれば3人合計の色えんぴつの数になるので、11＋29＋7＝47個です。","grade":4,"difficulty":1},{"id":"sb974","question":"Aさんがあめを23個、Bさんが19個、Cさんが29個持っています。3人合わせてあめは何個ありますか？","answer":"71","meaning":"Aさん・Bさん・Cさんそれぞれが持っているあめの個数を全部たし合わせれば3人合計のあめの数になるので、23＋19＋29＝71個です。","grade":4,"difficulty":1},{"id":"sb975","question":"Aさんがあめを19個、Bさんが19個、Cさんが11個持っています。3人合わせてあめは何個ありますか？","answer":"49","meaning":"Aさん・Bさん・Cさんそれぞれが持っているあめの個数を全部たし合わせれば3人合計のあめの数になるので、19＋19＋11＝49個です。","grade":4,"difficulty":1},{"id":"sb976","question":"Aさんがみかんを30個、Bさんが13個、Cさんが26個持っています。3人合わせてみかんは何個ありますか？","answer":"69","meaning":"Aさん・Bさん・Cさんそれぞれが持っているみかんの個数を全部たし合わせれば3人合計のみかんの数になるので、30＋13＋26＝69個です。","grade":4,"difficulty":1},{"id":"sb977","question":"りんごを35個持っていました。5個あげて、その後6個もらいました。今、りんごは何個ありますか？","answer":"36","meaning":"はじめの35個からあげた5個を引き、そのあとにもらった6個をたせば今の個数になるので、35－5＋6＝36個です。","grade":4,"difficulty":1},{"id":"sb978","question":"Aさんがみかんを7個、Bさんが30個、Cさんが24個持っています。3人合わせてみかんは何個ありますか？","answer":"61","meaning":"Aさん・Bさん・Cさんそれぞれが持っているみかんの個数を全部たし合わせれば3人合計のみかんの数になるので、7＋30＋24＝61個です。","grade":4,"difficulty":1},{"id":"sb979","question":"Aさんがノートを29個、Bさんが17個、Cさんが18個持っています。3人合わせてノートは何個ありますか？","answer":"64","meaning":"Aさん・Bさん・Cさんそれぞれが持っているノートの個数を全部たし合わせれば3人合計のノートの数になるので、29＋17＋18＝64個です。","grade":4,"difficulty":1},{"id":"sb980","question":"りんごを23個持っていました。3個あげて、その後11個もらいました。今、りんごは何個あります